rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function hasFirebaseAuth() {
      return request.auth != null;
    }

    function appUserPath(uid) {
      return /databases/$(database)/documents/appUsers/$(uid);
    }

    function isAuthenticated() {
      return hasFirebaseAuth()
        && exists(appUserPath(request.auth.uid))
        && get(appUserPath(request.auth.uid)).data.active == true;
    }

    // Reserved for future role-based policies. Server Admin SDK operations
    // bypass rules; client access requires an active appUsers document.
    function isAdmin() {
      return isAuthenticated()
        && (request.auth.token.admin == true
          || request.auth.token.role == 'admin'
          || get(appUserPath(request.auth.uid)).data.role == 'admin');
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function isNullableString(value) {
      return value == null || value is string;
    }

    function isNullableTimestamp(value) {
      return value == null || value is timestamp;
    }

    function isIsoDate(value) {
      return value is string
        && value.matches('^\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])$');
    }

    function isClockTime(value) {
      return value is string
        && value.matches('^([01]\\d|2[0-3]):[0-5]\\d$');
    }

    function isMonthId(value) {
      return value is string
        && value.matches('^\\d{4}-(0[1-9]|1[0-2])$');
    }

    function validCalendarColorMap(colors) {
      return colors is map
        && colors.keys().size() == 30
        && colors.keys().hasOnly([
          'worked', 'firstShift', 'secondShift', 'nightShift', 'bhp',
          'l4Active', 'l4Inactive', 'l4Reported', 'uw', 'uz', 'nn', 'nu',
          'ni', 'opd', 'krw', 'wzn', 'overtime50', 'overtime100',
          'nightHours', 'shortage', 'privateTime', 'manualCorrection',
          'requiresReview', 'blocker', 'warning', 'dayOff', 'weekend',
          'publicHoliday', 'future', 'outsideEmployment'
        ]);
    }

    function validCalendarAppearance(data) {
      return data.keys().hasAll([
          'version', 'text_colors', 'background_colors',
          'created_at', 'created_by', 'updated_at', 'updated_by'
        ])
        && data.keys().hasOnly([
          'version', 'text_colors', 'background_colors',
          'created_at', 'created_by', 'updated_at', 'updated_by'
        ])
        && data.version == 1
        && validCalendarColorMap(data.text_colors)
        && validCalendarColorMap(data.background_colors)
        && hasModificationMetadata(data);
    }

    function hasEmployeeReference(data) {
      return isNonEmptyString(data.employee_id)
        && isNonEmptyString(data.teta_number);
    }

    function hasModificationMetadata(data) {
      return data.created_at is timestamp
        && isNonEmptyString(data.created_by)
        && data.updated_at is timestamp
        && isNonEmptyString(data.updated_by);
    }

    function hasCreateMetadata(data) {
      return hasModificationMetadata(data)
        && data.created_at == request.time
        && data.updated_at == request.time
        && data.created_by == request.auth.uid
        && data.updated_by == request.auth.uid;
    }

    function hasUpdateMetadata(data) {
      return hasModificationMetadata(data)
        && data.created_at == resource.data.created_at
        && data.created_by == resource.data.created_by
        && data.updated_at == request.time
        && data.updated_by == request.auth.uid;
    }

    function monthExistsAndIsOpen(monthId) {
      return exists(/databases/$(database)/documents/months/$(monthId))
        && get(/databases/$(database)/documents/months/$(monthId)).data.is_settled == false;
    }

    function validEmployee(data) {
      return data.keys().hasAll([
          'teta_number',
          'first_name',
          'last_name',
          'is_active',
          'employment_start_date',
          'employment_end_date',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && data.keys().hasOnly([
          'teta_number',
          'first_name',
          'last_name',
          'pesel',
          'passport_number',
          'foreign_document_number',
          'phone_number',
          'citizenship',
          'gender',
          'first_toyota_employment_date',
          'medical_examination_date',
          'medical_valid_until',
          'medical_examination_type',
          'is_active',
          'department_id',
          'shift_assignment',
          'employment_start_date',
          'employment_end_date',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && data.teta_number is string
        && isNonEmptyString(data.first_name)
        && isNonEmptyString(data.last_name)
        && (!data.keys().hasAny(['pesel']) || isNullableString(data.pesel))
        && (!data.keys().hasAny(['passport_number'])
          || isNullableString(data.passport_number))
        && (!data.keys().hasAny(['foreign_document_number'])
          || isNullableString(data.foreign_document_number))
        && (!data.keys().hasAny(['phone_number'])
          || isNullableString(data.phone_number))
        && (!data.keys().hasAny(['citizenship'])
          || data.citizenship == null
          || (data.citizenship is string
            && data.citizenship.matches('^[A-Z]{2}$')))
        && (!data.keys().hasAny(['gender'])
          || data.gender == null
          || data.gender in ['K', 'M'])
        && (!data.keys().hasAny(['first_toyota_employment_date'])
          || isNullableTimestamp(data.first_toyota_employment_date))
        && (!data.keys().hasAny(['medical_examination_date'])
          || isNullableTimestamp(data.medical_examination_date))
        && (!data.keys().hasAny(['medical_valid_until'])
          || isNullableTimestamp(data.medical_valid_until))
        && (!data.keys().hasAny(['medical_examination_type'])
          || data.medical_examination_type == null
          || data.medical_examination_type in [
            'PRODUKCJA', 'MAGAZYNIER', 'PRODUKCJA_HL_PU'
          ])
        && (!data.keys().hasAny([
            'medical_examination_date', 'medical_valid_until'
          ])
          || data.medical_examination_date == null
          || data.medical_valid_until == null
          || data.medical_valid_until >= data.medical_examination_date)
        && data.is_active is bool
        && (!data.keys().hasAny(['department_id'])
          || isNullableString(data.department_id))
        && (!data.keys().hasAny(['shift_assignment'])
          || data.shift_assignment == null
          || data.shift_assignment in ['RED', 'WHITE', 'BLUE'])
        && isNullableTimestamp(data.employment_start_date)
        && isNullableTimestamp(data.employment_end_date)
        && hasModificationMetadata(data);
    }

    function validDepartment(data) {
      return data.keys().hasAll([
          'name',
          'shift_mode',
          'active',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && data.keys().hasOnly([
          'name',
          'shift_mode',
          'active',
          'rotation_anchor_week_start',
          'rotation_base_assignment',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && isNonEmptyString(data.name)
        && data.shift_mode in ['UNKNOWN', 'TWO_SHIFT', 'THREE_SHIFT']
        && data.active is bool
        && (!data.keys().hasAny(['rotation_anchor_week_start'])
          || data.rotation_anchor_week_start == null
          || isIsoDate(data.rotation_anchor_week_start))
        && (!data.keys().hasAny(['rotation_base_assignment'])
          || data.rotation_base_assignment == null
          || data.rotation_base_assignment is map)
        && hasModificationMetadata(data);
    }

    function validShiftInterval(interval) {
      return interval is map
        && interval.keys().hasAll(['start_time', 'end_time'])
        && interval.keys().hasOnly(['start_time', 'end_time'])
        && isClockTime(interval.start_time)
        && isClockTime(interval.end_time)
        && interval.start_time != interval.end_time;
    }

    function validShiftHoursVersion(data) {
      return data.keys().hasAll([
          'valid_from', 'intervals', 'active', 'note',
          'created_at', 'created_by', 'updated_at', 'updated_by'
        ])
        && data.keys().hasOnly([
          'valid_from', 'intervals', 'active', 'note',
          'created_at', 'created_by', 'updated_at', 'updated_by'
        ])
        && isIsoDate(data.valid_from)
        && data.intervals is map
        && data.intervals.keys().hasAll(['FIRST', 'SECOND', 'NIGHT'])
        && data.intervals.keys().hasOnly(['FIRST', 'SECOND', 'NIGHT'])
        && validShiftInterval(data.intervals.FIRST)
        && validShiftInterval(data.intervals.SECOND)
        && validShiftInterval(data.intervals.NIGHT)
        && data.active is bool
        && isNullableString(data.note)
        && hasModificationMetadata(data);
    }

    function validGroupShift(value) {
      return value in ['FIRST', 'SECOND', 'NIGHT'];
    }

    function validDepartmentShiftCorrection(data) {
      return data.keys().hasAll([
          'department_id', 'effective_date', 'shift_mode',
          'group_assignments', 'status', 'note',
          'created_at', 'created_by', 'updated_at', 'updated_by'
        ])
        && data.keys().hasOnly([
          'department_id', 'effective_date', 'shift_mode',
          'group_assignments', 'status', 'note',
          'created_at', 'created_by', 'updated_at', 'updated_by'
        ])
        && data.department_id in [
          'metal', 'szwalnia', 'montaz', 'pu', 'headliner', 'magazyn'
        ]
        && isIsoDate(data.effective_date)
        && data.shift_mode in ['TWO_SHIFT', 'THREE_SHIFT']
        && data.group_assignments is map
        && (
          (
            data.shift_mode == 'TWO_SHIFT'
            && data.group_assignments.keys().hasAll(['RED', 'WHITE'])
            && data.group_assignments.keys().hasOnly(['RED', 'WHITE'])
            && data.group_assignments.RED in ['FIRST', 'SECOND']
            && data.group_assignments.WHITE in ['FIRST', 'SECOND']
            && data.group_assignments.RED != data.group_assignments.WHITE
          )
          || (
            data.shift_mode == 'THREE_SHIFT'
            && data.group_assignments.keys().hasAll(['RED', 'WHITE', 'BLUE'])
            && data.group_assignments.keys().hasOnly(['RED', 'WHITE', 'BLUE'])
            && validGroupShift(data.group_assignments.RED)
            && validGroupShift(data.group_assignments.WHITE)
            && validGroupShift(data.group_assignments.BLUE)
            && data.group_assignments.RED != data.group_assignments.WHITE
            && data.group_assignments.RED != data.group_assignments.BLUE
            && data.group_assignments.WHITE != data.group_assignments.BLUE
          )
        )
        && data.status in ['ACTIVE', 'CANCELLED']
        && isNullableString(data.note)
        && hasModificationMetadata(data);
    }

    function validEmployeeAssignment(data) {
      return data.keys().hasAll([
          'employee_id',
          'teta_number',
          'department_id',
          'shift_assignment',
          'valid_from',
          'valid_to',
          'status',
          'note',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && data.keys().hasOnly([
          'employee_id',
          'teta_number',
          'department_id',
          'shift_assignment',
          'valid_from',
          'valid_to',
          'status',
          'note',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && hasEmployeeReference(data)
        && isNullableString(data.department_id)
        && (data.shift_assignment == null
          || data.shift_assignment in ['RED', 'WHITE', 'BLUE'])
        && isIsoDate(data.valid_from)
        && (data.valid_to == null || isIsoDate(data.valid_to))
        && (data.valid_to == null || data.valid_to >= data.valid_from)
        && data.status in ['ACTIVE', 'CANCELLED']
        && isNullableString(data.note)
        && hasModificationMetadata(data);
    }

    function validScheduleCorrection(data) {
      return data.keys().hasAll([
          'employee_id',
          'teta_number',
          'date',
          'kind',
          'planned_shift',
          'planned_hours',
          'note',
          'status',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && data.keys().hasOnly([
          'employee_id',
          'teta_number',
          'date',
          'kind',
          'planned_shift',
          'planned_hours',
          'note',
          'status',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && hasEmployeeReference(data)
        && isIsoDate(data.date)
        && data.kind in [
          'FIRST_SHIFT',
          'SECOND_SHIFT',
          'NIGHT_SHIFT',
          'DAY_OFF',
          'PUBLIC_HOLIDAY_WORK',
          'BHP'
        ]
        && (data.planned_shift == null
          || data.planned_shift in ['FIRST', 'SECOND', 'NIGHT'])
        && (data.planned_hours == null
          || (data.planned_hours is number
            && data.planned_hours >= 0
            && data.planned_hours <= 24))
        && isNullableString(data.note)
        && data.status in ['ACTIVE', 'CANCELLED']
        && hasModificationMetadata(data);
    }

    function validDailyValue(data) {
      return data.keys().hasAll([
          'employee_id',
          'teta_number',
          'date',
          'hours',
          'source',
          'import_id',
          'note',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && data.keys().hasOnly([
          'employee_id',
          'teta_number',
          'date',
          'hours',
          'source',
          'import_id',
          'note',
          'manual_override',
          'work_time_correction',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && hasEmployeeReference(data)
        && isIsoDate(data.date)
        && data.hours is number
        && data.hours >= 0
        && data.hours <= 24
        && data.source in ['manual', 'attendance_import']
        && isNullableString(data.note)
        && (
          (
            data.source == 'manual'
            && data.import_id == null
            && (
              !data.keys().hasAny(['manual_override'])
              || data.manual_override == null
            )
            && validWorkTimeCorrection(data)
          )
          || (
            data.source == 'attendance_import'
            && isNonEmptyString(data.import_id)
            && validManualOverride(data)
            && validWorkTimeCorrection(data)
          )
        )
        && hasModificationMetadata(data);
    }

    function validWorkTimeCorrection(data) {
      return !data.keys().hasAny(['work_time_correction'])
        || data.work_time_correction == null
        || (
          data.work_time_correction is map
          && data.work_time_correction.keys().hasAll([
            'planned_shift',
            'planned_start_time',
            'planned_end_time',
            'actual_start_time',
            'actual_end_time',
            'classification_override'
          ])
          && data.work_time_correction.keys().hasOnly([
            'planned_shift',
            'planned_start_time',
            'planned_end_time',
            'actual_start_time',
            'actual_end_time',
            'classification_override'
          ])
          && data.work_time_correction.planned_shift in [
            'FIRST',
            'SECOND',
            'NIGHT'
          ]
          && isClockTime(data.work_time_correction.planned_start_time)
          && isClockTime(data.work_time_correction.planned_end_time)
          && isClockTime(data.work_time_correction.actual_start_time)
          && isClockTime(data.work_time_correction.actual_end_time)
          && data.work_time_correction.classification_override == null
        );
    }

    function validManualOverride(data) {
      return !data.keys().hasAny(['manual_override'])
        || data.manual_override == null
        || (
          data.manual_override is map
          && data.manual_override.keys().hasAll([
            'hours',
            'note',
            'actor_uid',
            'updated_at'
          ])
          && data.manual_override.keys().hasOnly([
            'hours',
            'note',
            'actor_uid',
            'updated_at'
          ])
          && data.manual_override.hours is number
          && data.manual_override.hours >= 0
          && data.manual_override.hours <= 24
          && isNullableString(data.manual_override.note)
          && data.manual_override.actor_uid == request.auth.uid
          && data.manual_override.updated_at == request.time
        );
    }

    function hasCanonicalDailyValueIdentity(monthId, dailyValueId, data) {
      return data.date[0:7] == monthId
        && dailyValueId == data.employee_id + '_' + data.date;
    }

    function validAbsence(data) {
      return data.keys().hasAll([
          'employee_id',
          'teta_number',
          'absence_code',
          'start_date',
          'end_date',
          'hours_per_day',
          'source',
          'import_id',
          'status',
          'note',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && data.keys().hasOnly([
          'employee_id',
          'teta_number',
          'absence_code',
          'start_date',
          'end_date',
          'hours_per_day',
          'linked_work_date',
          'source',
          'import_id',
          'status',
          'note',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && hasEmployeeReference(data)
        && data.absence_code in [
          'L4',
          'UW',
          'UZ',
          'NN',
          'NU',
          'NI',
          'OPD',
          'KRW',
          'WZN'
        ]
        && isIsoDate(data.start_date)
        && isIsoDate(data.end_date)
        && data.start_date <= data.end_date
        && (data.hours_per_day == null
          || (data.hours_per_day is number
            && data.hours_per_day >= 0
            && data.hours_per_day <= 24))
        && (
          !data.keys().hasAny(['linked_work_date'])
          || data.linked_work_date == null
          || isIsoDate(data.linked_work_date)
        )
        && (
          data.absence_code == 'WZN'
          || !data.keys().hasAny(['linked_work_date'])
          || data.linked_work_date == null
        )
        && data.source in ['manual', 'absence_import']
        && (
          (data.source == 'manual' && data.import_id == null)
          || (data.source == 'absence_import' && isNonEmptyString(data.import_id))
        )
        && data.status in ['ACTIVE', 'CANCELLED']
        && isNullableString(data.note)
        && hasModificationMetadata(data);
    }

    function validEmployeeEntitlement(data) {
      return data.keys().hasAll([
          'employee_id',
          'teta_number',
          'type',
          'accommodation_variant_key',
          'valid_from',
          'valid_to',
          'status',
          'note',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && data.keys().hasOnly([
          'employee_id',
          'teta_number',
          'type',
          'accommodation_variant_key',
          'valid_from',
          'valid_to',
          'status',
          'note',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && hasEmployeeReference(data)
        && data.type in [
          'UDT',
          'OWN_HOUSING_ALLOWANCE',
          'COMPANY_ACCOMMODATION'
        ]
        && (
          (
            data.type == 'COMPANY_ACCOMMODATION'
            && isNonEmptyString(data.accommodation_variant_key)
          )
          || (
            data.type != 'COMPANY_ACCOMMODATION'
            && data.accommodation_variant_key == null
          )
        )
        && isIsoDate(data.valid_from)
        && (data.valid_to == null || isIsoDate(data.valid_to))
        && (data.valid_to == null || data.valid_to >= data.valid_from)
        && data.status in ['ACTIVE', 'CANCELLED']
        && isNullableString(data.note)
        && hasModificationMetadata(data);
    }

    function validSettlementReview(data) {
      return data.keys().hasAll([
          'month_id',
          'employee_id',
          'teta_number',
          'review_status',
          'review_note',
          'reviewed_at',
          'reviewed_by',
          'deposit_return_override',
          'deposit_return_note',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && data.keys().hasOnly([
          'month_id',
          'employee_id',
          'teta_number',
          'review_status',
          'review_note',
          'reviewed_at',
          'reviewed_by',
          'deposit_return_override',
          'deposit_return_note',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && isMonthId(data.month_id)
        && hasEmployeeReference(data)
        && data.review_status in [
          'DRAFT',
          'NEEDS_REVIEW',
          'NEEDS_CORRECTION',
          'CHECKED'
        ]
        && data.review_note is string
        && (
          data.deposit_return_override == null
          || (
            data.deposit_return_override is number
            && data.deposit_return_override >= 0
          )
        )
        && data.deposit_return_note is string
        && data.reviewed_at is timestamp
        && data.reviewed_by == request.auth.uid
        && hasModificationMetadata(data);
    }

    function hasCanonicalReviewStateIdentity(monthId, reviewStateId, data) {
      return data.month_id == monthId
        && reviewStateId == data.employee_id;
    }

    function hasCanonicalAbsenceOwner(monthId, data) {
      return data.start_date[0:7] == monthId;
    }

    function validAdjustment(data) {
      return data.keys().hasAll([
          'employee_id',
          'teta_number',
          'category',
          'direction',
          'amount',
          'note',
          'status',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && data.keys().hasOnly([
          'employee_id',
          'teta_number',
          'category',
          'direction',
          'amount',
          'note',
          'status',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && hasEmployeeReference(data)
        && data.category in [
          'MANUAL_BONUS',
          'MANUAL_DEDUCTION',
          'OTHER'
        ]
        && data.direction in ['INCREASE', 'DECREASE']
        && (
          (data.category == 'MANUAL_BONUS' && data.direction == 'INCREASE')
          || (data.category == 'MANUAL_DEDUCTION'
            && data.direction == 'DECREASE')
          || data.category == 'OTHER'
        )
        && data.amount is number
        && data.amount >= 0
        && data.note is string
        && data.status in ['ACTIVE', 'CANCELLED']
        && hasModificationMetadata(data);
    }

    function validPayrollSetting(data) {
      return data.keys().hasAll([
          'setting_key',
          'variant_key',
          'variant_name',
          'amount',
          'tax_type',
          'valid_from',
          'valid_to',
          'active',
          'description',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && data.keys().hasOnly([
          'setting_key',
          'variant_key',
          'variant_name',
          'amount',
          'tax_type',
          'valid_from',
          'valid_to',
          'active',
          'description',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && isNonEmptyString(data.setting_key)
        && isNullableString(data.variant_key)
        && isNullableString(data.variant_name)
        && (
          data.setting_key != 'accommodation_allowance'
          || (
            isNonEmptyString(data.variant_key)
            && isNonEmptyString(data.variant_name)
          )
        )
        && data.amount is number
        && data.amount >= 0
        && data.tax_type in ['GROSS', 'NET']
        && isMonthId(data.valid_from)
        && (data.valid_to == null || isMonthId(data.valid_to))
        && (data.valid_to == null || data.valid_to >= data.valid_from)
        && data.active is bool
        && data.description is string
        && hasModificationMetadata(data);
    }

    match /appUsers/{userId} {
      allow read: if hasFirebaseAuth()
        && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    match /appConfig/calendarAppearance {
      allow read: if isAuthenticated();
      allow create: if isAdmin()
        && validCalendarAppearance(request.resource.data)
        && hasCreateMetadata(request.resource.data);
      allow update: if isAdmin()
        && validCalendarAppearance(request.resource.data)
        && hasUpdateMetadata(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'version', 'text_colors', 'background_colors',
          'updated_at', 'updated_by'
        ]);
      allow delete: if false;
    }

    match /payrollSettings/{settingId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin()
        && validPayrollSetting(request.resource.data)
        && request.resource.data.active == true
        && hasCreateMetadata(request.resource.data);
      allow update: if isAdmin()
        && validPayrollSetting(request.resource.data)
        && hasUpdateMetadata(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'valid_to', 'active', 'tax_type', 'updated_at', 'updated_by'
        ])
        && (
          !resource.data.keys().hasAll(['tax_type'])
          || request.resource.data.tax_type == resource.data.tax_type
        )
        && (
          request.resource.data.active == resource.data.active
          || (
            resource.data.active == true
            && request.resource.data.active == false
          )
        );
      allow delete: if false;
    }

    match /shiftHoursVersions/{versionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && validShiftHoursVersion(request.resource.data)
        && request.resource.data.active == true
        && hasCreateMetadata(request.resource.data);
      allow update, delete: if false;
    }

    match /departmentShiftCorrections/{correctionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && validDepartmentShiftCorrection(request.resource.data)
        && request.resource.data.status == 'ACTIVE'
        && hasCreateMetadata(request.resource.data);
      allow update: if isAuthenticated()
        && resource.data.status == 'ACTIVE'
        && validDepartmentShiftCorrection(request.resource.data)
        && hasUpdateMetadata(request.resource.data)
        && request.resource.data.status == 'CANCELLED'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'updated_at', 'updated_by'
        ]);
      allow delete: if false;
    }

    match /departments/{departmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && departmentId.matches('^[a-z0-9][a-z0-9-]{0,63}$')
        && validDepartment(request.resource.data)
        && hasCreateMetadata(request.resource.data);
      allow update: if isAuthenticated()
        && validDepartment(request.resource.data)
        && hasUpdateMetadata(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'shift_mode',
          'active',
          'rotation_anchor_week_start',
          'rotation_base_assignment',
          'updated_at',
          'updated_by'
        ]);
      allow delete: if false;
    }

    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && validEmployee(request.resource.data)
        && hasCreateMetadata(request.resource.data);
      allow update: if isAuthenticated()
        && validEmployee(request.resource.data)
        && hasUpdateMetadata(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'teta_number',
          'first_name',
          'last_name',
          'pesel',
          'passport_number',
          'foreign_document_number',
          'phone_number',
          'citizenship',
          'gender',
          'first_toyota_employment_date',
          'medical_examination_date',
          'medical_valid_until',
          'medical_examination_type',
          'is_active',
          'department_id',
          'shift_assignment',
          'employment_start_date',
          'employment_end_date',
          'updated_at',
          'updated_by'
        ]);
      allow delete: if false;
    }

    match /employeeAssignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && validEmployeeAssignment(request.resource.data)
        && request.resource.data.status == 'ACTIVE'
        && hasCreateMetadata(request.resource.data);
      allow update: if isAuthenticated()
        && validEmployeeAssignment(request.resource.data)
        && hasUpdateMetadata(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'valid_to',
          'status',
          'note',
          'updated_at',
          'updated_by'
        ]);
      allow delete: if false;
    }

    match /employeeEntitlements/{entitlementId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && validEmployeeEntitlement(request.resource.data)
        && request.resource.data.status == 'ACTIVE'
        && hasCreateMetadata(request.resource.data);
      allow update: if isAuthenticated()
        && resource.data.status == 'ACTIVE'
        && validEmployeeEntitlement(request.resource.data)
        && hasUpdateMetadata(request.resource.data)
        && (
          (
            request.resource.data.status == 'ACTIVE'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'valid_to',
              'note',
              'updated_at',
              'updated_by'
            ])
          )
          || (
            request.resource.data.status == 'CANCELLED'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status',
              'updated_at',
              'updated_by'
            ])
          )
        );
      allow delete: if false;
    }

    match /months/{monthId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && monthId.matches('^\\d{4}-(0[1-9]|1[0-2])$')
        && request.resource.data.keys().hasAll([
          'year',
          'month',
          'month_start',
          'month_end',
          'is_settled',
          'calculation_version',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && request.resource.data.keys().hasOnly([
          'year',
          'month',
          'month_start',
          'month_end',
          'is_settled',
          'calculation_version',
          'created_at',
          'created_by',
          'updated_at',
          'updated_by'
        ])
        && request.resource.data.year is int
        && request.resource.data.month is int
        && request.resource.data.month >= 1
        && request.resource.data.month <= 12
        && int(monthId[0:4]) == request.resource.data.year
        && int(monthId[5:7]) == request.resource.data.month
        && request.resource.data.month_start is timestamp
        && request.resource.data.month_end is timestamp
        && request.resource.data.month_start == timestamp.date(
          request.resource.data.year,
          request.resource.data.month,
          1
        )
        && (
          (
            request.resource.data.month < 12
            && request.resource.data.month_end == timestamp.date(
              request.resource.data.year,
              request.resource.data.month + 1,
              1
            ) - duration.value(1, 'ms')
          )
          || (
            request.resource.data.month == 12
            && request.resource.data.month_end == timestamp.date(
              request.resource.data.year + 1,
              1,
              1
            ) - duration.value(1, 'ms')
          )
        )
        && request.resource.data.is_settled == false
        && request.resource.data.calculation_version is int
        && request.resource.data.calculation_version == 0
        && hasCreateMetadata(request.resource.data);
      allow update: if isAuthenticated()
        && hasUpdateMetadata(request.resource.data)
        && request.resource.data.year == resource.data.year
        && request.resource.data.month == resource.data.month
        && request.resource.data.month_start == resource.data.month_start
        && request.resource.data.month_end == resource.data.month_end
        && (
          (
            resource.data.is_settled == false
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'is_settled',
              'calculation_status',
              'calculation_started_at',
              'calculation_completed_at',
              'calculation_version',
              'calculation_error',
              'calculation_input_hash',
              'calculation_run_id',
              'calculation_blocker_count',
              'calculation_warning_count',
              'settled_at',
              'settled_by',
              'updated_at',
              'updated_by'
            ])
            && request.resource.data.calculation_version is int
            && request.resource.data.calculation_version >= resource.data.calculation_version
            && (!request.resource.data.is_settled
              || (request.resource.data.calculation_status == 'completed'
                && request.resource.data.calculation_blocker_count == 0
                && request.resource.data.settled_at == request.time
                && request.resource.data.settled_by == request.auth.uid))
          )
          || (
            resource.data.is_settled == true
            && request.resource.data.is_settled == false
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'is_settled',
              'calculation_status',
              'calculation_input_hash',
              'settled_at',
              'settled_by',
              'updated_at',
              'updated_by'
            ])
            && request.resource.data.calculation_status == 'queued'
            && request.resource.data.calculation_input_hash == null
            && request.resource.data.settled_at == null
            && request.resource.data.settled_by == null
          )
        );
      allow delete: if false;

      match /employeeSettlements/{settlementId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && settlementId == request.resource.data.employee_id
          && hasEmployeeReference(request.resource.data)
          && request.resource.data.keys().hasAll([
            'employee_id',
            'teta_number',
            'totals',
            'warnings',
            'calculated_at',
            'calculation_version',
            'calculation_run_id',
            'input_hash',
            'status',
            'blocker_count',
            'warning_count',
            'result'
          ])
          && request.resource.data.keys().hasOnly([
            'employee_id',
            'teta_number',
            'totals',
            'warnings',
            'calculated_at',
            'calculation_version',
            'calculation_run_id',
            'input_hash',
            'status',
            'blocker_count',
            'warning_count',
            'result'
          ])
          && request.resource.data.calculated_at == request.time
          && request.resource.data.calculation_version is int
          && request.resource.data.calculation_version > 0
          && isNonEmptyString(request.resource.data.calculation_run_id)
          && isNonEmptyString(request.resource.data.input_hash)
          && request.resource.data.status in ['complete', 'blocked']
          && request.resource.data.blocker_count is int
          && request.resource.data.blocker_count >= 0
          && request.resource.data.warning_count is int
          && request.resource.data.warning_count >= request.resource.data.blocker_count
          && request.resource.data.warnings is list
          && request.resource.data.totals is map
          && request.resource.data.result is map;
        allow delete: if isAuthenticated() && monthExistsAndIsOpen(monthId);
      }

      match /recoveryPoints/{recoveryPointId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && request.resource.data.keys().hasAll([
            'month_id',
            'input_hash',
            'created_at',
            'created_by',
            'item_count',
            'summary',
            'snapshot'
          ])
          && request.resource.data.keys().hasOnly([
            'month_id',
            'input_hash',
            'created_at',
            'created_by',
            'item_count',
            'summary',
            'snapshot'
          ])
          && request.resource.data.month_id == monthId
          && isNonEmptyString(request.resource.data.input_hash)
          && request.resource.data.created_at == request.time
          && request.resource.data.created_by == request.auth.uid
          && request.resource.data.item_count is int
          && request.resource.data.item_count >= 0
          && request.resource.data.summary is map
          && request.resource.data.snapshot is map;
        allow delete: if isAuthenticated() && monthExistsAndIsOpen(monthId);
        allow update: if false;
      }

      match /reviewStates/{reviewStateId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && validSettlementReview(request.resource.data)
          && hasCanonicalReviewStateIdentity(
            monthId,
            reviewStateId,
            request.resource.data
          )
          && request.resource.data.reviewed_at == request.time
          && hasCreateMetadata(request.resource.data);
        allow update: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && validSettlementReview(request.resource.data)
          && hasCanonicalReviewStateIdentity(
            monthId,
            reviewStateId,
            request.resource.data
          )
          && request.resource.data.reviewed_at == request.time
          && hasUpdateMetadata(request.resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'review_status',
            'review_note',
            'reviewed_at',
            'reviewed_by',
            'deposit_return_override',
            'deposit_return_note',
            'updated_at',
            'updated_by'
          ]);
        allow delete: if false;
      }

      match /dailyValues/{dailyValueId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && validDailyValue(request.resource.data)
          && request.resource.data.source == 'manual'
          && hasCanonicalDailyValueIdentity(
            monthId,
            dailyValueId,
            request.resource.data
          )
          && hasCreateMetadata(request.resource.data);
        allow update: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && resource.data.source == 'manual'
          && request.resource.data.source == 'manual'
          && hasUpdateMetadata(request.resource.data)
          && request.resource.data.hours is number
          && request.resource.data.hours >= 0
          && request.resource.data.hours <= 24
          && isNullableString(request.resource.data.note)
          && validWorkTimeCorrection(request.resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'hours',
            'note',
            'work_time_correction',
            'updated_at',
            'updated_by'
          ]);
        allow update: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && resource.data.source == 'attendance_import'
          && request.resource.data.source == 'attendance_import'
          && hasUpdateMetadata(request.resource.data)
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              'manual_override'
            ])
            || validManualOverride(request.resource.data)
          )
          && validWorkTimeCorrection(request.resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'manual_override',
            'work_time_correction',
            'updated_at',
            'updated_by'
          ]);
        allow delete: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && resource.data.source == 'manual';
      }

      match /scheduleCorrections/{correctionId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && validScheduleCorrection(request.resource.data)
          && request.resource.data.date[0:7] == monthId
          && request.resource.data.status == 'ACTIVE'
          && hasCreateMetadata(request.resource.data);
        allow update: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && resource.data.status == 'ACTIVE'
          && validScheduleCorrection(request.resource.data)
          && request.resource.data.date[0:7] == monthId
          && hasUpdateMetadata(request.resource.data)
          && (
            (
              request.resource.data.status == 'ACTIVE'
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'kind',
                'planned_shift',
                'planned_hours',
                'note',
                'updated_at',
                'updated_by'
              ])
            )
            || (
              request.resource.data.status == 'CANCELLED'
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'status',
                'updated_at',
                'updated_by'
              ])
            )
          );
        allow delete: if false;
      }

      match /absences/{absenceId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && validAbsence(request.resource.data)
          && hasCanonicalAbsenceOwner(monthId, request.resource.data)
          && request.resource.data.status == 'ACTIVE'
          && hasCreateMetadata(request.resource.data);
        allow update: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && resource.data.source == 'manual'
          && resource.data.status == 'ACTIVE'
          && validAbsence(request.resource.data)
          && hasCanonicalAbsenceOwner(monthId, request.resource.data)
          && hasUpdateMetadata(request.resource.data)
          && (
            (
              request.resource.data.status == 'ACTIVE'
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'absence_code',
                'start_date',
                'end_date',
                'hours_per_day',
                'linked_work_date',
                'note',
                'updated_at',
                'updated_by'
              ])
            )
            || (
              resource.data.absence_code == 'L4'
              && resource.data.source == 'manual'
              && request.resource.data.absence_code == 'L4'
              && request.resource.data.status == 'ACTIVE'
              && request.resource.data.source == 'absence_import'
              && isNonEmptyString(request.resource.data.import_id)
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'start_date',
                'end_date',
                'source',
                'import_id',
                'linked_work_date',
                'note',
                'updated_at',
                'updated_by'
              ])
            )
            || (
              request.resource.data.status == 'CANCELLED'
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'status',
                'updated_at',
                'updated_by'
              ])
            )
          );
        allow delete: if false;
      }

      match /adjustments/{adjustmentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && validAdjustment(request.resource.data)
          && request.resource.data.status == 'ACTIVE'
          && hasCreateMetadata(request.resource.data);
        allow update: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && resource.data.status == 'ACTIVE'
          && validAdjustment(request.resource.data)
          && hasUpdateMetadata(request.resource.data)
          && (
            (
              request.resource.data.status == 'ACTIVE'
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'category',
                'direction',
                'amount',
                'note',
                'updated_at',
                'updated_by'
              ])
            )
            || (
              request.resource.data.status == 'CANCELLED'
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'status',
                'updated_at',
                'updated_by'
              ])
            )
          );
        allow delete: if false;
      }

      match /imports/{importId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && monthExistsAndIsOpen(monthId)
          && request.resource.data.keys().hasAll([
            'import_type',
            'file_name',
            'storage_path',
            'status',
            'uploaded_at',
            'uploaded_by'
          ])
          && request.resource.data.keys().hasOnly([
            'import_type',
            'file_name',
            'storage_path',
            'status',
            'uploaded_at',
            'uploaded_by'
          ])
          && request.resource.data.import_type in [
            'attendance',
            'absences',
            'l4'
          ]
          && isNonEmptyString(request.resource.data.file_name)
          && isNonEmptyString(request.resource.data.storage_path)
          && request.resource.data.status == 'pending'
          && request.resource.data.uploaded_at == request.time
          && request.resource.data.uploaded_by == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /auditLog/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll([
          'entity_path',
          'action',
          'actor_uid',
          'occurred_at',
          'changes'
        ])
        && request.resource.data.keys().hasOnly([
          'entity_path',
          'action',
          'actor_uid',
          'occurred_at',
          'changes'
        ])
        && isNonEmptyString(request.resource.data.entity_path)
        && request.resource.data.action in [
          'create',
          'update',
          'delete',
          'settle'
        ]
        && request.resource.data.actor_uid == request.auth.uid
        && request.resource.data.occurred_at == request.time
        && request.resource.data.changes is map;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
